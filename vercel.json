{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "api/cron.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/api/cron.php", "dest": "/api/cron.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "crons": [
    {
      "path": "/api/cron.php",
      "schedule": "0 23 * * *"
    }
  ]
}