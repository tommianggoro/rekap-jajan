{
  "functions": {
    "api/webhook.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "api/cron.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/api/webhook.php", "dest": "/api/webhook.php" },
    { "src": "/api/cron.php", "dest": "/api/cron.php" },
    { "src": "/dashboard/(.*)", "dest": "/dashboard/$1" },
    { "src": "/$", "status": 301, "headers": { "Location": "/dashboard/" } }
  ],
  "crons": [
    {
      "path": "/api/cron.php",
      "schedule": "0 23 * * *"
    }
  ]
}